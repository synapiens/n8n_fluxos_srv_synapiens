              "type": "string"
            },
            {
              "id": "38b5ab89-c551-4c39-b29a-796716494d0c",
              "name": "body.cliente_id",
              "value": "={{ $json.body.cliente_id }}",
              "type": "string"
            },
            {
              "id": "e43b9249-615b-4daa-829c-bb845a34576f",
              "name": "body.emp_nome_reduzido",
              "value": "={{ $json.body.emp_nome_reduzido }}",
              "type": "string"
            },
            {
              "id": "11d051f2-f23d-4000-af52-4f05eb580321",
              "name": "body.cnpj_raiz",
              "value": "={{ $json.body.cnpj_raiz }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "b43c015f-a950-44e1-9558-0cbcd18ae35e",
      "name": "Set Context",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        224,
        400
      ]
    },
    {
      "parameters": {
        "url": "={{ 'https://oezifbbcnqfpjakyrohh.supabase.co/storage/v1/object/conta_upload/' + $json.file_path }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file",
              "outputPropertyName": "csvFile"
            }
          }
        }
      },
      "id": "6ddffd55-6eaa-41ab-ab91-3e558aa621ae",
      "name": "Download CSV do Storage",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        432,
        400
      ],
      "credentials": {
        "supabaseApi": {
          "id": "XZF8BL3CGNL9YXQR",
          "name": "Supa Sancal DRE"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{\n  (() => {\n    try {\n      const http = $('HTTP Request').first().json;\n\n      if (http.error || http.code) {\n        return {\n          success: false,\n          message: 'Erro ao gravar no Supabase.',\n          error: http.message || http.error || JSON.stringify(http)\n        };\n      }\n\n      const total = $('Parse HTTP').first().json.total;\n\n      return {\n        success: true,\n        message: `Gravação concluída com sucesso. ${total} registros gravados.`,\n        records_upserted: total\n      };\n\n    } catch (e) {\n      return {\n        success: false,\n        message: 'Erro inesperado ao processar resposta.',\n        error: e.message\n      };\n    }\n  })()\n}}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "460ce1d3-6155-43fa-be78-78250cc96dbd",
      "name": "Responder Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        1280,
        400
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Nó Code: \"Montar Batch\"\nconst ctx = $('Set Context').first().json;\n\nconst cliente_id = ctx.body.cliente_id;\nconst cnpj_raiz  = ctx.body.cnpj_raiz;\nconst reduz_emp  = ctx.body.emp_nome_reduzido;\n\nconst rows = items.map(item => ({\n  cliente_id,\n  reduz_emp,\n  cnpj_raiz,\n  conta_estru:  item.json.codigo,\n  conta_grau:   item.json.nivel,\n  conta_descri: item.json.descricao,\n  conta_reduz:  item.json.reduzido ?? null,\n  // is_analitica: item.json.is_analitica,\n}));\n\nconst BATCH_SIZE = 500;\nconst batches = [];\nfor (let i = 0; i < rows.length; i += BATCH_SIZE) {\n  batches.push({ json: { rows: rows.slice(i, i + BATCH_SIZE), total: rows.length } });\n}\n\nreturn batches;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        848,
        400
      ],
      "id": "234d9ff1-2445-47fc-a048-0d56c6ae1d13",
      "name": "Parse HTTP"
    },
    {
      "parameters": {
        "jsCode": "const binaryBuffer = await this.helpers.getBinaryDataBuffer(0, 'csvFile');\nconst content = binaryBuffer.toString('latin1');\n\nconst SKIP_PATTERNS = [\n  /^;*$/,\n  /^Listagem/i,\n  /^Empresa:/i,\n  /^CNPJ:/i,\n  /^C[oó]digo;/i,\n];\n\nconst rows = [];\n\nfor (const rawLine of content.split('\\n')) {\n  const line = rawLine.replace(/\\r/g, '').trim();\n  if (!line) continue;\n  if (SKIP_PATTERNS.some(p => p.test(line))) continue;\n\n  const cols = line.split(';');\n  const codigo    = (cols[0] || '').trim();\n  const reduzido  = (cols[3] || '').trim();\n  const descricao = (cols[6] || '').trim();\n\n  if (!codigo || !descricao) continue;\n\n  const nivel = codigo.split('.').length;\n\n  rows.push({\n    json: {\n      codigo,\n      ...(reduzido ? { reduzido } : {}),\n      descricao,\n      nivel,\n      is_analitica: reduzido !== '',\n    }\n  });\n}\n\nif (rows.length === 0) throw new Error('Nenhuma linha válida encontrada no CSV.');\n\nreturn rows;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        656,
        400
      ],
      "id": "364f1548-e33b-452d-8d8d-6a7e7053677c",
      "name": "Parse Arquivo"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://oezifbbcnqfpjakyrohh.supabase.co/rest/v1/dre_plano_contabil?on_conflict=cliente_id,cnpj_raiz,conta_estru",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Prefer",
              "value": "resolution=merge-duplicates"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{$json.rows}}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1056,
        400
      ],
      "id": "a67c206c-022f-44cc-8f04-dacd02a859ec",
      "name": "Grava Plano",
      "credentials": {
        "supabaseApi": {
          "id": "XZF8BL3CGNL9YXQR",
          "name": "Supa Sancal DRE"
        }
      }
    }
