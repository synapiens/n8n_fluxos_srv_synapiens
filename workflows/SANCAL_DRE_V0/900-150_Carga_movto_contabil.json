    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{\n  (() => {\n    try {\n      const http = $('HTTP Request').first().json;\n\n      if (http.error || http.code) {\n        return {\n          success: false,\n          message: 'Erro ao gravar no Supabase.',\n          error: http.message || http.error || JSON.stringify(http)\n        };\n      }\n\n      const total = $('Parse HTTP').first().json.total;\n\n      return {\n        success: true,\n        message: `Gravação concluída com sucesso. ${total} registros gravados.`,\n        records_upserted: total\n      };\n\n    } catch (e) {\n      return {\n        success: false,\n        message: 'Erro inesperado ao processar resposta.',\n        error: e.message\n      };\n    }\n  })()\n}}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "d88a6057-89a4-4ead-b373-69eedb0f54a5",
      "name": "Responder Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        208,
        576
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Parse HTTP - Montar batches para upsert rápido\nconst BATCH_SIZE = 500;\nconst batches = [];\n\nfor (let i = 0; i < items.length; i += BATCH_SIZE) {\n  const batch = items.slice(i, i + BATCH_SIZE).map(item => item.json);\n  \n  batches.push({\n    json: {\n      rows: batch,\n      total: items.length\n    }\n  });\n}\n\nreturn batches;"
      },
