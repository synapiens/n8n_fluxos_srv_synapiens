          "id": "xiqdphq7OrN8BBMi",
          "name": "Apify Instagran Monitor"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const shortCode = $('Edit Fields').first().json.short_code;\nconst now = new Date().toISOString();\n\nreturn $input.all().map(item => {\n  const c = item.json;\n  const commentId = String(c.id ?? '');\n\n  return {\n    json: {\n      post_id:           shortCode,\n      comment_id:        commentId,\n      comment_text:      c.text ?? '',\n      comment_username:  c.ownerUsername ?? '',\n      comment_timestamp: c.timestamp ?? null,\n      likes_count:       c.likesCount ?? 0,\n      replies_count:     c.repliesCount ?? (c.replies?.length ?? 0),\n      captured_at:       now,\n      replies: (c.replies ?? []).map(r => ({\n        comment_id:      commentId,\n        reply_id:        String(r.id ?? ''),\n        reply_text:      r.text ?? '',\n        reply_username:  r.ownerUsername ?? '',\n        reply_timestamp: r.timestamp ?? null,\n        likes_count:     r.likesCount ?? 0,\n        captured_at:     now\n      }))\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
