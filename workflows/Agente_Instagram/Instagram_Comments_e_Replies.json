    {
      "parameters": {
        "operation": "Run actor and get dataset",
        "actorId": {
          "__rl": true,
          "value": "SbK00X0JYCPblD2wp",
          "mode": "list",
          "cachedResultName": "Instagram Comments Scraper (apify/instagram-comment-scraper)",
          "cachedResultUrl": "https://console.apify.com/actors/SbK00X0JYCPblD2wp/input"
        },
        "customBody": "={\n    \"directUrls\": [\n        \"{{ $json.url }}\"\n    ],\n    \"includeNestedComments\": true,\n    \"isNewestComments\": true,\n    \"resultsLimit\": {{$json.comments_count}}\n}"
      },
      "type": "@apify/n8n-nodes-apify.apify",
      "typeVersion": 1,
      "position": [
        5120,
